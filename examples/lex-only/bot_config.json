{
  "name": "simple-greeting-bot",
  "description": "Simple greeting bot for testing",
  "type": "Bot",
  "idle_session_ttl": 300,
  "child_directed": false,
  "locales": {
    "en_US": {
      "description": "US English locale",
      "confidence_threshold": 0.4,
      "voice_settings": {
        "voice_id": "Joanna",
        "engine": "standard"
      },
      "intents": {
        "GreetingIntent": {
          "description": "Greeting intent",
          "sample_utterances": [
            "Hello",
            "Hi",
            "Hey",
            "Good morning",
            "Good afternoon"
          ],
          "closing_prompt": {
            "message": "Hello! How can I help you today?"
          }
        }
      }
    }
  }
}